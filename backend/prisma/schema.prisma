generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CompanyGroup {
  id        String @id @default(uuid())
  groupCode String @unique
  groupName String

  description String?

  isActive Boolean @default(true)

  companies Company[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company_groups")
}

model Company {
  id String @id @default(uuid())

  companyGroupId String?

  companyCode String @unique
  companyName String

  registrationNo String?
  taxNumber      String?

  parentCompanyId String?

  isActive Boolean @default(true)

  companyGroup CompanyGroup? @relation(fields: [companyGroupId], references: [id])

  branches          Branch[]
  approvalWorkflows ApprovalWorkflow[]

  departments        Department[]
  hrRequestTemplates HrRequestTemplate[]
  hrRequestTypes     HrRequestType[]

  employees           Employee[]
  employeeAssignments EmployeeCompanyAssignment[]
  documentTemplates   DocumentTemplate[]
  projects            Project[]
  workCategories      WorkCategory[]
  taskTypes           TaskType[]
  companySettings     CompanySetting[]
  holidays            Holiday[]
  leaveTypes          LeaveType[]
  leavePolicies       LeavePolicy[]
  documentTypes       EmployeeDocumentType[]
  resourceTypes       ResourceType[]
  resources           Resource[]
  employeeResources   EmployeeResource[]

  assetTypes AssetType[]
  assets     Asset[]

  onboardingTemplates OnboardingTemplate[]
  employeeOnboardings EmployeeOnboarding[]

  salaryComponents    SalaryComponent[]
  employeeSalaries    EmployeeSalary[]
  employeeTaxProfiles EmployeeTaxProfile[]
  employeeDeductions  EmployeeDeduction[]
  payrollRuns         PayrollRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

model Branch {
  id String @id @default(uuid())

  companyId String

  branchCode String
  branchName String

  isActive Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])

  departments   Department[]
  employees     Employee[]
  projects      Project[]
  holidays      Holiday[]
  leavePolicies LeavePolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("branches")
}

model Department {
  id String @id @default(uuid())

  companyId String
  branchId  String

  departmentCode String
  departmentName String

  isActive Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  employees     Employee[]
  leavePolicies LeavePolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("departments")
}

model Employee {
  id String @id @default(uuid())

  employeeCode String @unique

  companyId    String
  branchId     String
  departmentId String

  firstName String
  lastName  String?

  email  String?
  mobile String?

  designationId String?

  designation Designation? @relation(fields: [designationId], references: [id])

  joiningDate DateTime?

  employeeType String?

  employmentStatus String @default("ACTIVE")

  isActive Boolean @default(true)

  managerId String?

  manager Employee? @relation("EmployeeManager", fields: [managerId], references: [id])

  subordinates    Employee[] @relation("EmployeeManager")
  managedProjects Project[]  @relation("ProjectManager")

  company    Company    @relation(fields: [companyId], references: [id])
  branch     Branch     @relation(fields: [branchId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])

  assignments      EmployeeCompanyAssignment[]
  separations      EmployeeSeparation[]
  hrRequests       HrRequest[]
  approvalActions  ApprovalTransactionStep[]   @relation("ApprovalApprover")
  approvalRequests ApprovalTransaction[]       @relation("TransactionRequester")
  teamMembers      ProjectTeamMember[]
  taskParticipants TaskParticipant[]
  taskSubmissions  TaskSubmission[]            @relation("TaskSubmissionEmployee")
  taskAssignments  TaskAssignmentHistory[]     @relation("TaskAssignmentEmployee")

  taskAssignedBy            TaskAssignmentHistory[]    @relation("TaskAssignedByEmployee")
  previousAssignments       TaskAssignmentHistory[]    @relation("TaskPreviousEmployee")
  taskReviews               TaskReview[]               @relation("TaskReviewer")
  projectAllocationsCreated ProjectTeamMember[]        @relation("ProjectTeamMemberAssignedBy")
  allocationChanges         ProjectTeamMemberHistory[]
  workSchedules             WorkSchedule[]
  workScheduleItems         WorkScheduleItem[]
  taskWorkSessions          TaskWorkSession[]
  workLogs                  WorkLogHeader[]
  leaveBalances             EmployeeLeaveBalance[]
  leaveRequests             LeaveRequest[]
  employeeShifts            EmployeeShift[]
  documents                 EmployeeDocument[]
  employeeResources         EmployeeResource[]

  employeeSalaries   EmployeeSalary[]
  taxProfiles        EmployeeTaxProfile[]
  employeeDeductions EmployeeDeduction[]
  payrollRuns        PayrollRunEmployee[]

  employeeAssets      EmployeeAsset[]
  employeeOnboardings EmployeeOnboarding[]

  assignedAssets EmployeeAsset[] @relation("EmployeeAssetAssignedBy")

  returnedAssets EmployeeAsset[] @relation("EmployeeAssetReturnedBy")

  assignedWorkScheduleItems WorkScheduleItem[] @relation("WorkScheduleAssignedBy")

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]

  @@index([employmentStatus])
  @@map("employees")
}

model EmployeeSeparation {
  id String @id @default(uuid())

  employeeId String

  separationType String
  // RESIGNATION
  // TERMINATION
  // RETIREMENT

  status String @default("SUBMITTED")
  // SUBMITTED
  // APPROVED
  // REJECTED
  // COMPLETED

  resignationDate DateTime?
  lastWorkingDate DateTime?

  reason String?

  approvalTransactionId String?

  approvedById String?

  completedById String?

  completedDate DateTime?

  clearanceRemarks String?

  employee  Employee           @relation(fields: [employeeId], references: [id])
  clearance EmployeeClearance?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@map("employee_separations")
}

model EmployeeCompanyAssignment {
  id String @id @default(uuid())

  employeeId String
  companyId  String

  allocation Decimal @default(100)

  startDate DateTime?
  endDate   DateTime?

  isActive Boolean @default(true)

  employee Employee @relation(fields: [employeeId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([companyId])
  @@map("employee_company_assignments")
}

model AuditLog {
  id String @id @default(uuid())

  entityName String
  entityId   String

  action String

  oldValue Json?
  newValue Json?

  userId String?

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model Designation {
  id String @id @default(uuid())

  designationCode String @unique
  designationName String

  level Int?

  isActive Boolean @default(true)

  employees     Employee[]
  leavePolicies LeavePolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("designations")
}

model HrRequest {
  id String @id @default(uuid())

  requestNo String @unique

  employeeId String

  requestTypeId String

  status String @default("PENDING")

  requestDate DateTime @default(now())

  remarks String?

  approvalTransactionId String?

  generatedFilePath String?

  employee Employee @relation(fields: [employeeId], references: [id])

  requestType HrRequestType @relation(fields: [requestTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hr_requests")
}

model HrRequestTemplate {
  id String @id @default(uuid())

  companyId String

  requestTypeId String

  templateName String

  templateBody String

  isActive Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])

  requestType HrRequestType @relation(fields: [requestTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hr_request_templates")
}

model HrRequestType {
  id String @id @default(uuid())

  companyId String

  requestCode String
  requestName String

  workflowId String?

  workflow ApprovalWorkflow? @relation(fields: [workflowId], references: [id])

  requiresApproval Boolean @default(true)

  autoGenerate Boolean @default(false)

  isActive Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])

  templates HrRequestTemplate[]
  requests  HrRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, requestCode])
  @@map("hr_request_types")
}

model ApprovalWorkflow {
  id String @id @default(uuid())

  workflowCode String @unique
  workflowName String

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  isActive Boolean @default(true)

  steps ApprovalWorkflowStep[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  approvalTransactions ApprovalTransaction[]
  requestTypes         HrRequestType[]

  @@map("approval_workflows")
}

model ApprovalWorkflowStep {
  id String @id @default(uuid())

  workflowId String

  stepNo Int

  approverType String
  approverRole String?

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id])

  createdAt DateTime @default(now())

  @@unique([workflowId, stepNo])
  @@map("approval_workflow_steps")
}

model ApprovalTransaction {
  id String @id @default(uuid())

  workflowId String

  entityType String
  entityId   String

  requestedById String?
  leaveRequest  LeaveRequest?

  requestedBy Employee? @relation("TransactionRequester", fields: [requestedById], references: [id])

  currentStep Int @default(1)

  status String @default("PENDING")

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id])

  approvalSteps  ApprovalTransactionStep[]
  workLogHeaders WorkLogHeader[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([status])
  @@map("approval_transactions")
}

model ApprovalTransactionStep {
  id String @id @default(uuid())

  transactionId String

  stepNo Int

  approverId String?
  approver   Employee? @relation("ApprovalApprover", fields: [approverId], references: [id])

  status String  @default("PENDING")
  action String?

  remarks String?

  actionDate DateTime?

  transaction ApprovalTransaction @relation(fields: [transactionId], references: [id])

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@index([approverId])
  @@map("approval_transaction_steps")
}

model DocumentTemplate {
  id String @id @default(uuid())

  companyId String?

  templateCode String
  templateName String

  templateContent String

  fileFormat String @default("PDF")

  isActive Boolean @default(true)

  company Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, templateCode])
  @@map("document_templates")
}

model Project {
  id String @id @default(uuid())

  projectCode String @unique
  projectName String

  description String?

  clientName    String?
  clientContact String?

  startDate DateTime?
  endDate   DateTime?

  contractValue Decimal?
  currency      String?

  status String @default("DRAFT")

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  projectmanagerId String?
  projectManager   Employee? @relation("ProjectManager", fields: [projectmanagerId], references: [id])

  createdBy   String?
  updatedBy   String?
  teamMembers ProjectTeamMember[]
  stages      ProjectStage[]
  tasks       ProjectTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([branchId])
  @@index([projectmanagerId])
  @@index([status])
  @@map("projects")
}

model ProjectTeamMember {
  id String @id @default(uuid())

  projectId  String
  employeeId String

  role String

  allocationPercentage Decimal @default(100)

  startDate DateTime?
  endDate   DateTime?

  assignedById String?

  isActive Boolean @default(true)

  allocationSource String? // MANUAL, BID_PLAN, REALLOCATION

  allocationStatus String @default("ACTIVE")

  remarks String?

  project    Project   @relation(fields: [projectId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id])
  assignedBy Employee? @relation("ProjectTeamMemberAssignedBy", fields: [assignedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([employeeId])
  @@map("project_team_members")
}

model ProjectTeamMemberHistory {
  id String @id @default(uuid())

  projectTeamMemberId String

  projectId  String
  employeeId String

  oldRole   String?
  newRole   String?
  changedBy Employee? @relation(fields: [employeeId], references: [id])

  oldAllocationPercentage Decimal?
  newAllocationPercentage Decimal?

  oldStartDate DateTime?
  newStartDate DateTime?

  oldEndDate DateTime?
  newEndDate DateTime?

  action String

  remarks String?

  changedById String?

  changedAt DateTime @default(now())

  @@index([projectTeamMemberId])
  @@index([projectId])
  @@index([employeeId])
  @@map("project_team_member_history")
}

model ProjectStage {
  id String @id @default(uuid())

  projectId String

  stageCode String
  stageName String

  description String?

  sequenceNo Int

  status String @default("OPEN")

  startDate DateTime?
  endDate   DateTime?

  project Project       @relation(fields: [projectId], references: [id])
  tasks   ProjectTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@map("project_stages")
}

model ProjectTask {
  id String @id @default(uuid())

  projectId String
  stageId   String

  taskCode String
  taskName String

  taskTypeId String?

  parentTaskId String?

  description String?

  priority String @default("MEDIUM")

  plannedHours         Decimal? @default(0)
  estimatedReviewHours Decimal? @default(0)
  completionPercentage Decimal? @default(0)

  startDate DateTime?
  dueDate   DateTime?

  status String @default("OPEN")

  project           Project            @relation(fields: [projectId], references: [id])
  workScheduleItems WorkScheduleItem[]

  stage             ProjectStage            @relation(fields: [stageId], references: [id])
  participants      TaskParticipant[]
  submissions       TaskSubmission[]
  assignmentHistory TaskAssignmentHistory[]
  taskType          TaskType?               @relation(fields: [taskTypeId], references: [id])

  parentTask   ProjectTask?  @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  workLogLines WorkLogLine[]

  subTasks ProjectTask[] @relation("TaskHierarchy")

  createdBy String?
  updatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, taskCode])
  @@index([projectId])
  @@index([stageId])
  @@index([status])
  @@map("project_tasks")
}

model TaskType {
  id String @id @default(uuid())

  companyId String?

  taskTypeCode String
  taskTypeName String

  description String?

  defaultPlannedHours Decimal?

  estimatedComplexity String?

  isBillable Boolean @default(true)

  isActive Boolean @default(true)

  company Company? @relation(fields: [companyId], references: [id])

  tasks ProjectTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, taskTypeCode])
  @@map("task_types")
}

model TaskParticipant {
  id String @id @default(uuid())

  taskId String

  employeeId String

  role String

  plannedHours Decimal? @default(0)

  actualHours Decimal? @default(0)

  status String @default("PENDING")

  task ProjectTask @relation(fields: [taskId], references: [id])

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, employeeId, role])
  @@index([taskId])
  @@index([employeeId])
  @@map("task_participants")
}

model TaskSubmission {
  id String @id @default(uuid())

  taskId String

  versionNo Int

  submissionNotes String?

  filePath String

  submittedById String

  status String @default("SUBMITTED")

  submittedAt DateTime @default(now())

  task ProjectTask @relation(fields: [taskId], references: [id])

  submittedBy Employee     @relation("TaskSubmissionEmployee", fields: [submittedById], references: [id])
  reviews     TaskReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, versionNo])
  @@index([taskId])
  @@map("task_submissions")
}

model TaskAssignmentHistory {
  id String @id @default(uuid())

  taskId String

  employeeId String

  role String

  action String

  previousEmployeeId String?
  previousEmployee   Employee? @relation("TaskPreviousEmployee", fields: [previousEmployeeId], references: [id])

  remarks String?

  assignedById String?

  task ProjectTask @relation(fields: [taskId], references: [id])

  employee Employee @relation("TaskAssignmentEmployee", fields: [employeeId], references: [id])

  assignedBy Employee? @relation("TaskAssignedByEmployee", fields: [assignedById], references: [id])

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([employeeId])
  @@map("task_assignment_history")
}

model TaskReview {
  id String @id @default(uuid())

  submissionId String

  reviewerId String

  decision String

  comments String?

  reviewHours Decimal? @default(0)
  reviewRound Int      @default(1)

  reviewedAt DateTime @default(now())

  submission TaskSubmission @relation(fields: [submissionId], references: [id])

  reviewer Employee @relation("TaskReviewer", fields: [reviewerId], references: [id])

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@index([reviewerId])
  @@map("task_reviews")
}

model WorkCategory {
  id String @id @default(uuid())

  categoryCode String
  categoryName String
  companyId    String?

  isBillable Boolean @default(true)

  isActive Boolean @default(true)

  company           Company?           @relation(fields: [companyId], references: [id])
  workScheduleItems WorkScheduleItem[]
  workLogLines      WorkLogLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, categoryCode])
}

model WorkSchedule {
  id String @id @default(uuid())

  employeeId String

  startDate DateTime
  endDate   DateTime

  status String @default("DRAFT")

  remarks String?

  employee Employee @relation(fields: [employeeId], references: [id])

  items WorkScheduleItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@map("work_schedules")
}

model WorkScheduleItem {
  id String @id @default(uuid())

  workScheduleId String

  workDate DateTime

  taskId String?

  workCategoryId String?
  employeeId     String

  title String

  description String?

  plannedHours Decimal @default(0)

  sourceType   String?
  parentItemId String?
  assignedById String?
  sequenceNo   Int?

  priority String @default("MEDIUM")

  status           String    @default("PLANNED")
  plannedStartTime DateTime?
  plannedEndTime   DateTime?

  workSchedule WorkSchedule @relation(fields: [workScheduleId], references: [id])

  task ProjectTask? @relation(fields: [taskId], references: [id])

  workCategory WorkCategory?     @relation(fields: [workCategoryId], references: [id])
  parentItem   WorkScheduleItem? @relation("WorkScheduleItemHierarchy", fields: [parentItemId], references: [id])

  childItems   WorkScheduleItem[] @relation("WorkScheduleItemHierarchy")
  employee     Employee           @relation(fields: [employeeId], references: [id])
  assignedBy   Employee?          @relation("WorkScheduleAssignedBy", fields: [assignedById], references: [id])
  workSessions TaskWorkSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workScheduleId])
  @@index([taskId, workDate])
  @@index([parentItemId])
  @@index([employeeId])
  @@index([assignedById])
  @@index([status])
  @@map("work_schedule_items")
}

model TaskWorkSession {
  id String @id @default(uuid())

  workScheduleItemId String

  employeeId String

  startedAt DateTime

  endedAt DateTime?

  detectedHours Decimal @default(0)

  confirmedHours Decimal @default(0)

  adjustmentRemarks String?

  status String @default("ACTIVE")

  workScheduleItem WorkScheduleItem @relation(fields: [workScheduleItemId], references: [id])

  employee     Employee      @relation(fields: [employeeId], references: [id])
  workLogLines WorkLogLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([workScheduleItemId])
  @@index([status])
  @@map("task_work_sessions")
}

model CompanySetting {
  id String @id @default(uuid())

  companyId String

  settingKey String

  settingValue String

  description String?

  company Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, settingKey])
  @@index([companyId])
  @@map("company_settings")
}

model WorkLogHeader {
  id String @id @default(uuid())

  employeeId String

  startDate DateTime
  endDate   DateTime

  totalHours Decimal @default(0)

  status String @default("DRAFT")

  submittedAt DateTime?
  approvedAt  DateTime?

  approvalTransactionId String?

  approvalTransaction ApprovalTransaction? @relation(fields: [approvalTransactionId], references: [id])

  remarks String?

  employee Employee @relation(fields: [employeeId], references: [id])

  lines WorkLogLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, startDate, endDate])
  @@index([status])
  @@index([approvalTransactionId])
  @@map("work_log_headers")
}

model WorkLogLine {
  id String @id @default(uuid())

  workLogHeaderId String

  workDate DateTime

  taskId            String?
  taskWorkSessionId String?

  workCategoryId String?

  hours      Decimal @default(0)
  sourceType String?

  remarks String?

  workLogHeader WorkLogHeader @relation(fields: [workLogHeaderId], references: [id])

  task ProjectTask? @relation(fields: [taskId], references: [id])

  workCategory    WorkCategory?    @relation(fields: [workCategoryId], references: [id])
  taskWorkSession TaskWorkSession? @relation(fields: [taskWorkSessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workLogHeaderId])
  @@index([taskId])
  @@index([workCategoryId])
  @@index([workDate])
  @@index([sourceType])
  @@index([taskWorkSessionId])
  @@map("work_log_lines")
}

model Holiday {
  id String @id @default(uuid())

  companyId String
  branchId  String?

  holidayCode String?

  holidayName String

  description String?

  holidayDate DateTime

  holidayType String

  isActive Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, branchId, holidayDate, holidayName])
  @@index([companyId])
  @@index([branchId])
  @@index([holidayDate])
  @@map("holidays")
}

model LeaveType {
  id String @id @default(uuid())

  companyId String

  leaveCode String
  leaveName String

  description String?

  isPaid Boolean @default(true)

  requiresApproval Boolean @default(true)

  allowHalfDay Boolean @default(false)

  isActive            Boolean @default(true)
  carryForwardAllowed Boolean @default(false)

  company          Company                @relation(fields: [companyId], references: [id])
  leavePolicies    LeavePolicy[]
  employeeBalances EmployeeLeaveBalance[]
  leaveRequests    LeaveRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, leaveCode])
  @@index([companyId])
  @@map("leave_types")
}

model LeavePolicy {
  id String @id @default(uuid())

  companyId     String
  branchId      String
  departmentId  String?
  designationId String?

  leaveTypeId String

  annualEntitlement Decimal @db.Decimal(5, 2)

  carryForwardLimit Decimal? @db.Decimal(5, 2)

  maxConsecutiveDays Int?

  allowNegativeBalance Boolean @default(false)

  maximumNegativeBalance Decimal? @db.Decimal(5, 2)

  accrualMethod String @default("YEARLY")

  accrualRate Decimal? @db.Decimal(5, 2)

  accrualWorkingDays Int?

  carryForwardExpiryMonths Int?

  isActive Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id])

  branch Branch @relation(fields: [branchId], references: [id])

  department Department? @relation(fields: [departmentId], references: [id])

  designation Designation? @relation(fields: [designationId], references: [id])

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, branchId, departmentId, designationId, leaveTypeId])
  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([designationId])
  @@index([leaveTypeId])
  @@map("leave_policies")
}

model EmployeeLeaveBalance {
  id String @id @default(uuid())

  employeeId  String
  leaveTypeId String

  year Int

  entitlement Decimal @db.Decimal(5, 2)

  used Decimal @default(0) @db.Decimal(5, 2)

  pending Decimal @default(0) @db.Decimal(5, 2)

  balance Decimal @db.Decimal(5, 2)

  isActive Boolean @default(true)

  employee Employee @relation(fields: [employeeId], references: [id])

  leaveType     LeaveType      @relation(fields: [leaveTypeId], references: [id])
  leaveRequests LeaveRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@map("employee_leave_balances")
}

model LeaveRequest {
  id String @id @default(uuid())

  employeeId String

  leaveTypeId String

  leaveBalanceId String?

  fromDate DateTime
  toDate   DateTime

  requestedDays Decimal @db.Decimal(5, 2)

  approvedDays Decimal? @db.Decimal(5, 2)

  isHalfDay Boolean @default(false)

  reason String?

  attachmentUrl String?

  status String @default("DRAFT")

  cancellationReason String?

  isActive Boolean @default(true)

  approvalTransactionId String?

  approvalTransaction ApprovalTransaction? @relation(fields: [approvalTransactionId], references: [id])

  employee Employee @relation(fields: [employeeId], references: [id])

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  leaveBalance EmployeeLeaveBalance? @relation(fields: [leaveBalanceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([approvalTransactionId])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([status])
  @@map("leave_requests")
}

model Attendance {
  id String @id @default(uuid())

  employeeId String

  attendanceDate DateTime

  checkInTime  DateTime?
  checkOutTime DateTime?

  shiftId String?

  status String
  // PRESENT
  // ABSENT
  // HALF_DAY
  // LEAVE
  // HOLIDAY
  // WEEK_OFF

  workedHours Decimal @default(0) @db.Decimal(5, 2)

  lateMinutes Int @default(0)

  earlyDepartureMinutes Int @default(0)

  overtimeMinutes Int @default(0)

  source String? @default("MANUAL")

  approvalStatus String? @default("APPROVED")

  remarks String?

  isActive Boolean @default(true)

  employee Employee @relation(fields: [employeeId], references: [id])

  shift Shift? @relation(fields: [shiftId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, attendanceDate])
  @@index([employeeId])
  @@index([attendanceDate])
  @@index([status])
  @@map("attendances")
}

model Shift {
